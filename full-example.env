# CursedContainer + Hytale full setup environment template
#
# Reminder: copy/rename this file to `.env` in the project root before starting compose.
# Example:
#   cp full-example.env .env
#
# Keep this file as a template and edit `.env` with your real values.

# Required: CurseForge API key
# Get one from: https://docs.curseforge.com/rest-api/#getting-started
CURSE_FORGE_API=replace_with_your_curseforge_api_key

# Host user/group that should own created files
# On Linux you can check with: id -u  and  id -g
PUID=1000
PGID=1000

# Absolute host path for Hytale server files
HYTALE_SERVER_FILES_PATH=/absolute/path/to/hytale-server-files/

# Absolute host path for Hytale mods folder
# This maps to: /app/mods inside cursedcontainer
# Most setups use: <HYTALE_SERVER_FILES_PATH>/mods
# Usually this should point to the same mods directory used by your Hytale server setup
HYTALE_MODS_PATH=/absolute/path/to/hytale-server-files/mods
